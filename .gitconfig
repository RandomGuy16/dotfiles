[user]
	email = aroon.delgado.25@gmail.com
	name = RandomGuy16
[core]
	editor = nvim
[init]
	defaultBranch = main
[pull]
	rebase = true
[alias]
	superlog = log --graph --abbrev-commit --decorate --date=relative --format=format:\"%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)\" --all
	st = status
	co = checkout
	br = branch
	cm = commit
	last = log -1 HEAD
	blamef = blame -w -C -C -C --color-by-age
	prunebr = 
